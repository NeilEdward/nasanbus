{
  "openapi": "3.1.0",
  "info": {
    "title": "NasanBus API",
    "description": "HTTP API for NasanBus services",
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local"
    }
  ],
  "paths": {
    "/api/v1/accounts": {
      "get": {
        "tags": [
          "account-controller"
        ],
        "operationId": "findAll",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Account"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "account-controller"
        ],
        "operationId": "create",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAccountRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/accounts/{id}": {
      "get": {
        "tags": [
          "account-controller"
        ],
        "operationId": "findById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateAccountRequest": {
        "type": "object",
        "properties": {
          "cognitoSub": {
            "type": "string",
            "maxLength": 100,
            "minLength": 0
          },
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 255,
            "minLength": 0
          },
          "firstName": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 100,
            "minLength": 0
          },
          "lastName": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 100,
            "minLength": 0
          },
          "phoneNumber": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 30,
            "minLength": 0
          }
        },
        "required": [
          "cognitoSub",
          "email"
        ]
      },
      "Account": {
        "type": "object",
        "properties": {
          "id": {
            "type": [
              "string",
              "null"
            ],
            "format": "uuid"
          },
          "cognitoSub": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "firstName": {
            "type": [
              "string",
              "null"
            ]
          },
          "lastName": {
            "type": [
              "string",
              "null"
            ]
          },
          "phoneNumber": {
            "type": [
              "string",
              "null"
            ]
          },
          "addedOn": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "addedBy": {
            "type": "string"
          },
          "updatedBy": {
            "type": "string"
          },
          "updatedOn": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "deletedBy": {
            "type": [
              "string",
              "null"
            ]
          },
          "deletedOn": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        },
        "required": [
          "addedBy",
          "cognitoSub",
          "email",
          "updatedBy"
        ]
      }
    }
  }
}